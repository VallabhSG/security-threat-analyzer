# ─── Ollama / LLM ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_NUM_CTX=1536
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0

# ─── Embeddings ──────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── FAISS / Retrieval ───────────────────────────────────────────────
FAISS_INDEX_PATH=faiss_index_real
RETRIEVER_K=5

# ─── Data Paths ──────────────────────────────────────────────────────
RAW_DATA_PATH=log_data.csv
PREPARED_DATA_PATH=prepared_logs.csv

# ─── Processing ──────────────────────────────────────────────────────
BATCH_SIZE=10000
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TARGET_SAMPLE_SIZE=2000000
